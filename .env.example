START_URL=https://mc.manuscriptcentral.com/kes

# Optional. If omitted, the script uses the built-in rejection message.
# REJECT_MESSAGE=Dear Author(s),\n\nThank you...
# REJECT_MESSAGE_FILE=reject-message.txt

# Run defaults. These can also be changed in the local UI.
# MAX_CHECKED=50
# SUBMITTED_OLDER_THAN_DAYS=30
# SLOW_MO=500
# QUEUE_START_PAGE=2
# MAX_REJECTED=4
# KEEP_OPEN=false

# Auto-login. Keep credentials out of the UI.
# AUTO_LOGIN=true
# LOGIN_USERNAME=your-login
# LOGIN_PASSWORD=your-password
# LOGIN_CREDENTIALS_FILE=login.env

# Report replay.
# REJECT_FROM_REPORT=logs/reports/2026-07-07T10-00-00-000Z.json
# REJECT_PROGRESS_FILE=logs/reports/2026-07-07T10-00-00-000Z.progress.json
